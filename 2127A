// https://codeforces.com/contest/2127/problem/A

#include <bits/stdc++.h>
using namespace std;
 
int mex(int a, int b, int c) {
    set<int> s = {a, b, c};
    for (int x = 0; ; x++)
        if (!s.count(x)) return x;
}
 
bool check(int a, int b, int c) {
    return mex(a,b,c) == max({a,b,c}) - min({a,b,c});
}
 
int main(){
    int t; cin >> t;
    while(t--) {
        int n; cin >> n;
        vector<int> a(n+1);
        for(int i = 1; i <= n; i++) cin >> a[i];
 
        int val = -1;
        bool ok = true;
        for(int i = 1; i <= n; i++) {
            if(a[i] == -1) continue;
            if(a[i] == 0) { ok = false; break; }
            if(val == -1) val = a[i];
            else if(val != a[i]) { ok = false; break; }
        }
        cout << (ok ? "Yes" : "No") << "\n";
    }
}
