#include <bits/stdc++.h>
using namespace std;
 
int main(){
    int t,n,x,y;
    cin >> t;
 
    while (t--){
            cin >> n;
            cin >> x;
            int mx = x;
 
            for (int i = 2; i <= n; i++){
                    cin >> y;
                    mx = max(mx, y);
                    x = y;
            }
 
            cout << mx << "\n";
    }
 
    return 0;
}
 
