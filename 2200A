#include <bits/stdc++.h>
using namespace std;
 
int t, n, v[11];
int max1 = INT_MIN;
int cnt = 0;
 
int main(){
  cin >> t;
  
  while (t--){
    cin >> n;
    for (int i = 1; i <= n; i++){
        cin >> v[i];
        if (v[i] > max1)
           max1 = v[i];
    }
    
    for (int i = 1; i <= n; i++){
        if (v[i] == max1)
           cnt++;
    }
    
    cout << cnt << "\n";
    cnt = 0;
    max1 = INT_MIN;
  }
  
  return 0;
}
