#include <bits/stdc++.h>
 
using namespace std;
 
void solve() {
    int n;
    cin >> n;
    vector<int> p(n);
    int max_pos = 0;
 
    for (int i = 0; i < n; i++) {
        cin >> p[i];
        if (p[i] == n) {
            max_pos = i;
        }
    }
 
    swap(p[0], p[max_pos]);
 
    for (int i = 0; i < n; i++) {
        cout << p[i] << (i == n - 1 ? "" : " ");
    }
    cout << endl;
}
 
int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    int t;
    cin >> t;
    while (t--) {
        solve();
    }
    return 0;
}
